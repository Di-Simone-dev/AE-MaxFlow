{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build with CMake (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B",
                "build",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-G",
                "Visual Studio 17 2022"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": []
        },
        {
            "label": "Compile (CMake build)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--config",
                "Debug"
            ],
            "dependsOn": ["Build with CMake (Debug)"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$msCompile"]
        },
        {
            "label": "Run maxflow",
            "type": "shell",
            "command": "${workspaceFolder}/build/Debug/maxflow.exe",
            "args": ["-fullsuite"],
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "problemMatcher": []
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "Remove-Item",
            "args": ["-Recurse", "-Force", "build"],
            "problemMatcher": []
        }
    ]
}
